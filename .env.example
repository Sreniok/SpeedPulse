# Timezone
TZ=UTC
APP_TIMEZONE=UTC
DOCKER_APPARMOR_PROFILE=docker-default

# Dashboard auth
# Leave credentials empty to create your account from the browser on first login.
# APP_SECRET_KEY and AUTH_SALT are auto-generated during setup.
DASHBOARD_PORT=8000
DASHBOARD_LOGIN_EMAIL=""
DASHBOARD_PASSWORD_HASH=""
DASHBOARD_PASSWORD=""
APP_SECRET_KEY=replace-with-32-plus-char-random-secret
AUTH_SALT=replace-with-random-hex-string
SECRETS_MASTER_KEY=replace-with-random-secret-master-key
# auto = detect from request (recommended), true = HTTPS only, false = HTTP
SESSION_COOKIE_SECURE=auto
# SESSION_TTL_SECONDS=43200
# LOGIN_MAX_ATTEMPTS=5
# LOGIN_WINDOW_SECONDS=900
# LOGIN_BLOCK_SECONDS=900
# RECOVERY_EMAIL=

# SMTP password (required for email reports — all other SMTP settings live in config.json)
SMTP_PASSWORD=

# Measurements database
POSTGRES_DB=speedpulse
POSTGRES_USER=speedpulse
POSTGRES_PASSWORD=replace-with-random-postgres-password
DATABASE_URL=postgresql+psycopg://speedpulse:replace-with-random-postgres-password@postgres:5432/speedpulse

# Scheduler overrides (env-only, not in config.json)
# HEALTH_CHECK_TIME=07:00
# LOG_ROTATION_TIME=02:00
# RUN_STARTUP_SPEEDTEST=false
# MANUAL_SPEEDTEST_COOLDOWN_SECONDS=300

# Example deployment notes:
# Local development:
# DASHBOARD_PORT=8000
# SESSION_COOKIE_SECURE=false
#
# Reverse proxy / HTTPS:
# SESSION_COOKIE_SECURE=true
#
# Non-UTC timezone example:
# TZ=Europe/Warsaw
# APP_TIMEZONE=Europe/Warsaw
