# Timezone
TZ=UTC
APP_TIMEZONE=UTC

# Dashboard auth
DASHBOARD_PORT=8000
DASHBOARD_LOGIN_EMAIL=admin@example.com
# Generate with: python3 generate_password_hash.py
DASHBOARD_PASSWORD_HASH=pbkdf2_sha256:390000:replace_salt:replace_hash
# Plain DASHBOARD_PASSWORD is deprecated — always use DASHBOARD_PASSWORD_HASH.
APP_SECRET_KEY=replace-with-32-plus-char-random-secret
AUTH_SALT=replace-with-random-hex-string
SESSION_TTL_SECONDS=43200
SESSION_COOKIE_SECURE=true
LOGIN_MAX_ATTEMPTS=5
LOGIN_WINDOW_SECONDS=900
LOGIN_BLOCK_SECONDS=900

# Recovery email for password resets (defaults to DASHBOARD_LOGIN_EMAIL)
# RECOVERY_EMAIL=

# SMTP settings (required)
SMTP_SERVER=smtp.example.com
SMTP_PORT=465
SMTP_USERNAME=stats@example.com
SMTP_PASSWORD=replace-with-smtp-password
EMAIL_FROM=stats@example.com
EMAIL_TO=alerts@example.com

# Optional scheduler overrides
HEALTH_CHECK_TIME=07:00
LOG_ROTATION_TIME=02:00
RUN_STARTUP_SPEEDTEST=false
MANUAL_SPEEDTEST_COOLDOWN_SECONDS=300
# Optional runtime-state store (session invalidation, login lockouts, reset tokens)
# STATE_DB_PATH=Archive/runtime_state.sqlite3

# Optional speedtest overrides
# Use official Ookla binary by default:
SPEEDTEST_EXE=speedtest
# Optional fixed server id for consistent testing (example: 38190)
SPEEDTEST_SERVER_ID=

# Data retention (overrides config.json data_retention section)
# KEEP_WEEKS=52
# KEEP_DAYS=30

# Deployment (used by deploy.sh)
# DEPLOY_USER=root
# DEPLOY_HOST=192.168.1.100
# DEPLOY_PATH=~/scripts/Speedtest
